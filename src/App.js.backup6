const ALL_STORES = STORE_CATALOG.flatMap(c => c.stores);
const DEFAULT_STORES = ["amazon", "etsy", "target"];
const MONTHS = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
const MONTH_NUMS = { Jan:"01",Feb:"02",Mar:"03",Apr:"04",May:"05",Jun:"06",Jul:"07",Aug:"08",Sep:"09",Oct:"10",Nov:"11",Dec:"12" };

const uid = () => Math.random().toString(36).slice(2, 9);
const Q = s => encodeURIComponent((s || "").trim());
const mkLinks = (q, ids, custom = []) => [
...ALL_STORES.filter(s => ids.includes(s.id)).map(s => ({ label: s.label, url: s.url + Q(q) })),
...custom.map(s => ({ label: s.label, url: s.url + Q(q) })),
];

// FIX: daysUntil now handles "Jan 15 2000" format (3-part string) AND "YYYY-MM-DD"
const daysUntil = d => {
if (!d) return null;
let dateStr = d;
// Handle "Mon DD YYYY" format stored by the birthday fields
const parts = d.trim().split(/\s+/);
if (parts.length >= 2 && MONTH_NUMS[parts[0]]) {
const month = MONTH_NUMS[parts[0]];
const day = parts[1] ? parts[1].padStart(2, "0") : "01";
const thisYear = new Date().getFullYear();
const yearPart = parts[2] || thisYear;
// Use current year for upcoming calculation
const md = `${month}-${day}`;
dateStr = `${thisYear}-${md}`;
const diff = Math.ceil((new Date(dateStr + "T12:00:00") - new Date()) / 86400000);
if (diff < 0) dateStr = `${thisYear + 1}-${md}`;
}
return Math.ceil((new Date(dateStr + "T12:00:00") - new Date()) / 86400000);
};

