// ─── ATOMS ────────────────────────────────────────────────────────────────────
function FL({ children }) {
return <div style={{ fontSize: 10, fontWeight: 800, letterSpacing: 1.5, color: C.muted, textTransform: "uppercase", marginBottom: 8 }}>{children}</div>;
}
function Chip({ label, active, onClick, gold }) {
return (
<button onClick={onClick} style={{
padding: "7px 14px", borderRadius: 999, cursor: "pointer", flexShrink: 0,
border: `1.5px solid ${active ? (gold ? C.gold : C.accent) : C.border}`,
background: active ? (gold ? C.goldL : C.accentL) : "transparent",
color: active ? (gold ? C.gold : C.accent) : C.sub,
fontSize: 13, fontWeight: 700, whiteSpace: "nowrap", transition: "all .13s", fontFamily: "inherit",
}}>{label}</button>
);
}
function TInput({ value, onChange, placeholder, type = "text" }) {
const [f, setF] = useState(false);
return (
<input value={value} onChange={onChange} placeholder={placeholder} type={type}
onFocus={() => setF(true)} onBlur={() => setF(false)}
style={{
width: "100%", padding: "11px 14px", fontSize: 14,
color: C.text, fontFamily: "inherit",
border: `1.5px solid ${f ? C.accent : C.border}`,
borderRadius: 12, background: C.card,
outline: "none", transition: "border-color .15s",
}}
/>
);
}
function Sep() {
return <div style={{ height: 1, background: C.border, margin: "2px 0" }} />;
}

// ─── BOTTOM SHEET ─────────────────────────────────────────────────────────────
function Sheet({ children, onClose, title }) {
return (
<div onClick={e => e.target === e.currentTarget && onClose()} style={{
position: "fixed", inset: 0, background: "rgba(26,23,20,.32)",
display: "flex", alignItems: "flex-end", zIndex: 200,
animation: "fade .18s ease",
}}>
<div style={{
width: "100%", maxWidth: 680, margin: "0 auto",
background: C.bg, borderRadius: "22px 22px 0 0",
padding: "10px 20px 80px", maxHeight: "90vh", overflowY: "auto",
animation: "up .22s ease",
}}>
<div style={{ width: 36, height: 4, borderRadius: 2, background: "#ddd", margin: "0 auto 18px" }} />
{title && <div style={{ fontSize: 18, fontWeight: 900, color: C.text, marginBottom: 16 }}>{title}</div>}
{children}
</div>
</div>
);
}

// ─── PHOTO PICKER ─────────────────────────────────────────────────────────────
function PhotoPicker({ photo, onPhoto, size = 52 }) {
const ref = useRef();
return (
<>
<div onClick={() => ref.current.click()} style={{
width: size, height: size, borderRadius: size / 3,
background: photo ? "transparent" : C.border,
border: `1.5px solid ${C.border}`,
display: "flex", alignItems: "center", justifyContent: "center",
cursor: "pointer", overflow: "hidden", flexShrink: 0,
}}>
{photo
? <img src={photo} style={{ width: "100%", height: "100%", objectFit: "cover" }} alt="" />
: <span style={{ fontSize: size * 0.4, color: C.muted }}>📷</span>
}
</div>
<input ref={ref} type="file" accept="image/*" style={{ display: "none" }}
onChange={e => {
const file = e.target.files[0];
if (!file) return;
const reader = new FileReader();
reader.onload = ev => onPhoto(ev.target.result);
reader.readAsDataURL(file);
}} />
</>
);
}

// ─── GIFT CARD ────────────────────────────────────────────────────────────────
function GiftCard({ gift, storeIds, customStores, idx, onWish, isWished }) {
const [open, setOpen] = useState(false);
const links = mkLinks(gift.searchQuery || gift.title, storeIds, customStores);
const bud = BUDGETS.find(b => b.id === gift.budget);
return (
<div style={{
background: C.card, border: `1.5px solid ${C.border}`,
borderRadius: 16, overflow: "hidden",
animation: `up .3s ease ${idx * .07}s both`,
}}>
<div onClick={() => setOpen(o => !o)} style={{ padding: "14px 16px", cursor: "pointer" }}>
<div style={{ display: "flex", alignItems: "flex-start", gap: 10 }}>
<div style={{
width: 28, height: 28, borderRadius: 8, flexShrink: 0,
background: C.accentL, display: "flex", alignItems: "center",
justifyContent: "center", fontSize: 13, fontWeight: 900, color: C.accent, marginTop: 1,
}}>{idx + 1}</div>
<div style={{ flex: 1 }}>
{bud && (
<span style={{
fontSize: 11, fontWeight: 800, background: "#f5f0eb",
color: C.sub, borderRadius: 6, padding: "2px 8px",
display: "inline-block", marginBottom: 5,
}}>{bud.label}</span>
)}
<div style={{ fontSize: 15, fontWeight: 800, color: C.text, lineHeight: 1.3 }}>
{gift.title}
</div>
<div style={{ marginTop: 4, display: "flex", alignItems: "center", gap: 6, flexWrap: "wrap" }}>
<span style={{ fontSize: 12, color: C.accent, fontWeight: 700 }}>↗ {gift.trendReason}</span>
{gift.category && (
<span style={{
fontSize: 10, fontWeight: 800, color: C.muted,
background: "#f0ebe4", borderRadius: 5, padding: "1px 6px",
letterSpacing: 0.3, textTransform: "uppercase",
}}>{gift.category}</span>
)}
{gift.priceHint && (
<span style={{
fontSize: 10, fontWeight: 800, borderRadius: 5, padding: "1px 6px",
background: gift.priceHint==="Budget"?"#e8f5e9":gift.priceHint==="Luxury"?"#fce4ec":gift.priceHint==="Premium"?"#fff3e0":"#f3e5f5",
color: gift.priceHint==="Budget"?"#388e3c":gift.priceHint==="Luxury"?"#c62828":gift.priceHint==="Premium"?"#e65100":"#7b1fa2",
}}>{gift.priceHint}</span>
)}
</div>
</div>
<div style={{ display: "flex", flexDirection: "column", alignItems: "center", gap: 6 }}>
{onWish && (
<button onClick={e => { e.stopPropagation(); onWish(gift, links); }} style={{
background: isWished ? C.goldL : "#f5f0eb",
border: `1.5px solid ${isWished ? C.gold : C.border}`,
borderRadius: 8, width: 32, height: 32, cursor: "pointer",
fontSize: 15, display: "flex", alignItems: "center", justifyContent: "center",
}}>{isWished ? "⭐" : "☆"}</button>
)}
<span style={{ color: C.muted, fontSize: 11 }}>{open ? "▲" : "▼"}</span>
</div>
</div>
</div>
{open && (
<div style={{ padding: "12px 16px 16px", borderTop: `1px solid ${C.border}` }}>
<p style={{ fontSize: 13, color: C.sub, lineHeight: 1.7, marginBottom: 14 }}>{gift.description}</p>
<div style={{ display: "flex", flexWrap: "wrap", gap: 7 }}>
{links.map((lk, i) => (
<a key={i} href={lk.url} target="_blank" rel="noreferrer" style={{
padding: "7px 13px", background: C.accent, color: "#fff",
borderRadius: 9, fontSize: 12, fontWeight: 800,
textDecoration: "none", display: "inline-flex", alignItems: "center", gap: 5,
}}>🛍 {lk.label}</a>
))}
</div>
</div>
)}
</div>
);
}

// ─── WISH LIST SHEET ──────────────────────────────────────────────────────────
function WishListSheet({ wishList, onRemove, onClear, onClose, myName, myBirthday }) {
const [copied, setCopied] = useState(false);
const doShare = () => {
const who = myName ? `${myName}'s` : "My";
const bdStr = myBirthday ? `\n  Birthday: ${myBirthday}` : "";
const text = `🎁 ${who} Wish List (via Pickwell)${bdStr}\n\n` +
wishList.map((item, i) =>
`${i + 1}. ${item.title}\n   ${item.storeLinks?.[0]?.url || ""}`
).join("\n\n") +
`\n\nFind the perfect gift → pickwell.com`;
if (navigator.share) {
navigator.share({ title: "My Wish List", text }).catch(() => {});
} else {
navigator.clipboard.writeText(text).then(() => {
setCopied(true);
setTimeout(() => setCopied(false), 2500);
});
}
};
return (
<Sheet onClose={onClose} title="⭐ My Wish List">
{wishList.length === 0 ? (
<div style={{ textAlign: "center", padding: "36px 20px",
border: `2px dashed ${C.border}`, borderRadius: 16,
color: C.muted, fontSize: 14, lineHeight: 1.7,
}}>
<div style={{ fontSize: 40, marginBottom: 10 }}>🎁</div>
Nothing saved yet.<br />
Select <strong style={{ color: C.gold }}>🎁 For Me</strong>, find gifts, tap ☆ to save.
</div>
) : (
<>
{(myName || myBirthday) && (
<div style={{
background: C.goldL, border: `1.5px solid #f9a82544`,
borderRadius: 14, padding: "12px 16px", marginBottom: 16,
display: "flex", alignItems: "center", gap: 12,
}}>
<span style={{ fontSize: 28 }}>🦊</span>
<div>
{myName && <div style={{ fontWeight: 800, fontSize: 15, color: C.text }}>{myName}</div>}
{myBirthday && <div style={{ fontSize: 12, color: C.gold, fontWeight: 700, marginTop: 2 }}>🎂 {myBirthday}</div>}
</div>
</div>
)}
<div style={{ display: "flex", justifyContent: "flex-end", marginBottom: 12 }}>
<button onClick={onClear} style={{
background: "none", border: "none", fontSize: 12,
color: C.muted, cursor: "pointer", fontFamily: "inherit", fontWeight: 700,
}}>Clear all</button>
</div>
<div style={{ display: "flex", flexDirection: "column", gap: 10, marginBottom: 16 }}>
{wishList.map((item, i) => (
<div key={item.id} style={{
background: C.card, border: `1.5px solid ${C.border}`,
borderRadius: 14, padding: "13px 16px",
display: "flex", alignItems: "flex-start", gap: 12,
animation: `up .25s ease ${i * .05}s both`,
}}>
<div style={{ flex: 1 }}>
<div style={{ fontWeight: 800, fontSize: 14, color: C.text, marginBottom: 3 }}>{item.title}</div>
<div style={{ fontSize: 12, color: C.accent, fontWeight: 700, marginBottom: 6 }}>↗ {item.trendReason}</div>
<div style={{ display: "flex", gap: 6, flexWrap: "wrap" }}>
{item.storeLinks?.map((lk, j) => (
<a key={j} href={lk.url} target="_blank" rel="noreferrer" style={{
padding: "5px 10px", background: "#f5f0eb", color: C.sub,
borderRadius: 7, fontSize: 11, fontWeight: 700, textDecoration: "none",
}}>🛍 {lk.label}</a>
))}
</div>
</div>
<button onClick={() => onRemove(item.id)} style={{
background: "none", border: "none", color: C.muted,
cursor: "pointer", fontSize: 20, lineHeight: 1, padding: 0,
}}>×</button>
</div>
))}
</div>
<button onClick={doShare} style={{
width: "100%", padding: 14, borderRadius: 13, border: "none",
background: C.accent, color: "#fff",
fontSize: 15, fontWeight: 800, cursor: "pointer", fontFamily: "inherit",
}}>
{copied ? "✓ Copied!" : "📤 Share My Wish List"}
</button>
<div style={{ fontSize: 11, color: C.muted, textAlign: "center", marginTop: 8 }}>
Opens iMessage, WhatsApp, Email — or copies to clipboard
</div>
</>
)}
</Sheet>
);
}

// ─── CUSTOM OCCASION INPUT ────────────────────────────────────────────────────
function CustomOccasionInput({ onSearch }) {
const [val, setVal] = useState("");
return (
<div style={{ display: "flex", gap: 8, marginTop: 4 }}>
<input
placeholder="✏️ Custom: Ramadan, Diwali, Nowruz..."
value={val}
onChange={e => setVal(e.target.value)}
onKeyDown={e => { if (e.key === "Enter" && val.trim()) { onSearch(val.trim()); setVal(""); } }}
style={{
flex: 1, padding: "9px 12px", fontSize: 12,
border: `1.5px solid ${C.border}`, borderRadius: 10,
background: C.card, color: C.text,
fontFamily: "inherit", outline: "none",
}}
/>
<button
onClick={() => { if (val.trim()) { onSearch(val.trim()); setVal(""); } }}
disabled={!val.trim()}
style={{
padding: "9px 14px", borderRadius: 10, border: "none",
background: val.trim() ? C.accent : C.border,
color: val.trim() ? "#fff" : C.muted,
fontSize: 12, fontWeight: 800,
cursor: val.trim() ? "pointer" : "not-allowed",
fontFamily: "inherit", flexShrink: 0,
}}>Find</button>
</div>
);
}

// ─── GROUPS SHEET ─────────────────────────────────────────────────────────────
function GroupsSheet({ groups, onLoadPerson, onCreate, onClose, onBulkSearch, bulkLoading, onDelete }) {
  const [openId, setOpenId] = useState(null);
  const [groupBudget, setGroupBudget] = useState("");
  const [budgetMode, setBudgetMode] = useState("Equal split");
  const [selectedOccasion, setSelectedOccasion] = useState("");
  const [customOcc, setCustomOcc] = useState("");
  const handleFind = (g) => {
    if (customOcc.trim()) {
      onBulkSearch(g, null, customOcc.trim(), groupBudget, budgetMode);
    } else if (selectedOccasion) {
      onBulkSearch(g, selectedOccasion, null, groupBudget, budgetMode);
    }
  };
  return (
    <Sheet onClose={onClose} title="👥 Groups">
      {groups.length === 0 && (
        <div style={{ textAlign: "center", color: C.muted, fontSize: 13, padding: "24px 0" }}>
          No groups yet. Add people to groups from the main search.
        </div>
      )}
      <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
        {groups.map(g => (
          <div key={g.id} style={{ background: C.card, border: `1.5px solid ${C.border}`, borderRadius: 16, overflow: "hidden" }}>
            <div onClick={() => setOpenId(openId === g.id ? null : g.id)} style={{ padding: "14px 16px", cursor: "pointer", display: "flex", alignItems: "center", gap: 12 }}>
              <span style={{ fontSize: 24 }}>{g.emoji}</span>
              <div style={{ flex: 1 }}>
                <div style={{ fontWeight: 800, fontSize: 15, color: C.text }}>{g.name}</div>
                <div style={{ fontSize: 12, color: C.muted }}>{g.people.length} people</div>
              </div>
              <span style={{ color: C.muted, fontSize: 12 }}>{openId === g.id ? "▲" : "▼"}</span>
            </div>
            {openId === g.id && (
              <>
                {g.people.map((p, i) => {
                  const rel = RELATIONS.find(r => r.id === p.relation);
                  const bd = daysUntil(p.birthday);
                  return (
                    <div key={p.id} onClick={() => { onLoadPerson(p); onClose(); }} style={{ padding: "11px 16px 11px 20px", borderTop: `1px solid ${C.border}`, cursor: "pointer", display: "flex", alignItems: "center", gap: 12 }}>
                      {p.photo ? <img src={p.photo} style={{ width: 36, height: 36, borderRadius: 10, objectFit: "cover" }} alt="" /> : <div style={{ width: 36, height: 36, borderRadius: 10, background: "#f5f0eb", display: "flex", alignItems: "center", justifyContent: "center", fontSize: 18 }}>{rel?.emoji}</div>}
                      <div style={{ flex: 1 }}>
                        <div style={{ fontWeight: 700, fontSize: 14, color: C.text }}>{p.name || rel?.label}</div>
                        <div style={{ fontSize: 12, color: C.muted }}>{[p.age, p.interests].filter(Boolean).join(" · ")}</div>
                        {bd !== null && bd >= 0 && bd <= 30 && (<div style={{ fontSize: 11, color: C.accent, fontWeight: 800 }}>🎂 Birthday in {bd}d</div>)}
                      </div>
                      <span style={{ color: C.muted, fontSize: 14 }}>→</span>
                    </div>
                  );
                })}
                {g.people.length > 0 && (
                  <div style={{ borderTop: `1px solid ${C.border}`, background: "#faf8f5", padding: "16px 16px 20px" }}>
                    <div style={{ fontSize: 13, fontWeight: 800, color: C.text, marginBottom: 14 }}>🎁 Find gifts for all {g.people.length} people</div>
                    <div style={{ background: C.card, border: `1.5px solid ${C.border}`, borderRadius: 14, padding: "14px 14px 16px", marginBottom: 12 }}>
                      <FL>Budget</FL>
                      <div style={{ display: "flex", flexWrap: "wrap", gap: 7, marginBottom: 10 }}>
                        {BUDGETS.map(b => (<Chip key={b.id} label={b.label} active={groupBudget === b.id} onClick={() => setGroupBudget(x => x === b.id ? "" : b.id)} />))}
                      </div>
                      <Sep />
                      <div style={{ marginTop: 10 }}>
                        <div style={{marginBottom:10}}><FL>Or enter amount</FL><input placeholder="e.g. 50, 200 total..." value={typeof groupBudget==="string" && groupBudget && !BUDGETS.find(b=>b.id===groupBudget) ? groupBudget : ""} onChange={e=>setGroupBudget(e.target.value)} style={{width:"100%",padding:"10px 14px",fontSize:13,border:"1.5px solid "+C.border,borderRadius:10,background:C.card,color:C.text,fontFamily:"inherit",outline:"none"}}/></div><FL>Budget Type</FL>
                        <div style={{ display: "flex", gap: 8 }}>
                          {["Equal split", "Shared gift"].map(mode => (
                            <button key={mode} onClick={() => setBudgetMode(mode)} style={{ flex: 1, padding: "10px 8px", borderRadius: 10, cursor: "pointer", border: `1.5px solid ${budgetMode === mode ? C.accent : C.border}`, background: budgetMode === mode ? C.accentL : C.card, color: budgetMode === mode ? C.accent : C.sub, fontSize: 13, fontWeight: 700, fontFamily: "inherit" }}>
                              {mode === "Equal split" ? "💰 Equal split" : "🎁 Shared gift"}
                            </button>
                          ))}
                        </div>
                      </div>
                    </div>
                    <div style={{ background: C.card, border: `1.5px solid ${C.border}`, borderRadius: 14, padding: "14px 14px 16px", marginBottom: 12 }}>
                      <FL>Occasion</FL>
                      <div style={{ display: "flex", gap: 7, overflowX: "auto", paddingBottom: 6 }}>
                        {OCCASIONS.map(o => (<Chip key={o.id} label={`${o.emoji} ${o.label}`} active={selectedOccasion === o.id && !customOcc} onClick={() => { setSelectedOccasion(x => x === o.id ? "" : o.id); setCustomOcc(""); }} />))}
                      </div>
                      <div style={{ marginTop: 10 }}>
                        <FL>Custom Occasion</FL>
                        <TInput placeholder="Ramadan, Diwali, Nowruz, Retirement..." value={customOcc} onChange={e => { setCustomOcc(e.target.value); if (e.target.value) setSelectedOccasion(""); }} />
                      </div>
                    </div>
                    <button onClick={() => handleFind(g)} disabled={bulkLoading} style={{ width: "100%", padding: 15, borderRadius: 14, border: "none", background: bulkLoading ? C.accentL : C.accent, color: bulkLoading ? C.accent : "#fff", fontSize: 15, fontWeight: 900, cursor: "pointer", fontFamily: "inherit", display: "flex", alignItems: "center", justifyContent: "center", gap: 10, transition: "all .2s" }}>
                      {bulkLoading ? (<><span style={{ width: 16, height: 16, borderRadius: "50%", border: `2px solid ${C.accentL}`, borderTopColor: C.accent, display: "inline-block", animation: "spin .7s linear infinite" }} />Finding gifts...</>) : `🎁 Find Gifts for ${g.name}`}
                    </button>
                  </div>
                )}
              </>
            )}
          </div>
        ))}
      </div>
    </Sheet>
  );
}


// ─── SAVE TO GROUP SHEET ──────────────────────────────────────────────────────
function SaveToGroupSheet({ person, groups, onSave, onClose }) {
const [sel, setSel] = useState(null);
const [newName, setNew] = useState("");
const [mode, setMode] = useState("pick");
const PRESETS = [
{ name: "Family", emoji: "👨‍👩‍👧" },
{ name: "Friends", emoji: "🤝" },
{ name: "Work", emoji: "💼" },
{ name: "Christmas", emoji: "🎄" },
];
const doSave = () => {
if (mode === "pick" && sel) { onSave("existing", sel, person); }
else if (mode === "new" && newName) {
const preset = PRESETS.find(p => p.name === newName);
onSave("new", { name: newName, emoji: preset?.emoji || "👥" }, person);
}
onClose();
};
const canSave = (mode === "pick" && sel) || (mode === "new" && newName);
return (
<Sheet onClose={onClose} title="👥 Save to Group">
{groups.length > 0 && (
<div style={{ marginBottom: 16 }}>
<FL>Add to existing group</FL>
<div style={{ display: "flex", flexDirection: "column", gap: 8 }}>
{groups.map(g => (
<button key={g.id} onClick={() => { setSel(g.id); setMode("pick"); }} style={{
padding: "11px 16px", borderRadius: 12, cursor: "pointer", textAlign: "left",
border: `1.5px solid ${sel === g.id && mode === "pick" ? C.accent : C.border}`,
background: sel === g.id && mode === "pick" ? C.accentL : C.card,
display: "flex", alignItems: "center", gap: 10, fontFamily: "inherit",
}}>
<span style={{ fontSize: 20 }}>{g.emoji}</span>
<span style={{ fontWeight: 700, color: C.text }}>{g.name}</span>
<span style={{ fontSize: 12, color: C.muted, marginLeft: "auto" }}>{g.people.length} people</span>
</button>
))}
</div>
</div>
)}
<FL>Create new group</FL>
<div style={{ display: "flex", gap: 7, flexWrap: "wrap", marginBottom: 10 }}>
{PRESETS.map(p => (
<button key={p.name} onClick={() => { setNew(p.name); setMode("new"); setSel(null); }} style={{
padding: "8px 14px", borderRadius: 10, cursor: "pointer",
border: `1.5px solid ${newName === p.name && mode === "new" ? C.accent : C.border}`,
background: newName === p.name && mode === "new" ? C.accentL : C.card,
color: C.sub, fontSize: 13, fontWeight: 700, fontFamily: "inherit",
}}>{p.emoji} {p.name}</button>
))}
</div>
<div style={{ display: "flex", gap: 8, marginBottom: 20 }}>
<TInput placeholder="Or type a custom name..." value={mode === "new" ? newName : ""}
onChange={e => { setNew(e.target.value); setMode("new"); setSel(null); }} />
</div>
<button onClick={doSave} disabled={!canSave} style={{
width: "100%", padding: 14, borderRadius: 13, border: "none",
background: canSave ? C.accent : C.border,
color: canSave ? "#fff" : C.muted,
fontSize: 15, fontWeight: 800,
cursor: canSave ? "pointer" : "not-allowed", fontFamily: "inherit",
}}>Save Person</button>
</Sheet>
);
}

// ─── CALENDAR SHEET ───────────────────────────────────────────────────────────
function CalendarSheet({ people, groups, onLoadPerson, onClose }) {
const allPeople = [
...people,
...groups.flatMap(g => g.people),
].filter((p, i, arr) => arr.findIndex(x => x.id === p.id) === i);

const events = allPeople
.filter(p => p.birthday || p.occasion)
.flatMap(p => {
const items = [];
if (p.birthday) {
const thisYear = new Date().getFullYear();
// FIX: handle both "Jan 15 2000" and "YYYY-MM-DD" formats
const parts = p.birthday.trim().split(/\s+/);
let dateStr;
if (parts.length >= 2 && MONTH_NUMS[parts[0]]) {
const month = MONTH_NUMS[parts[0]];
const day = (parts[1] || "1").padStart(2, "0");
dateStr = `${thisYear}-${month}-${day}`;
} else {
const bd = p.birthday.slice(5); // MM-DD from YYYY-MM-DD
dateStr = `${thisYear}-${bd}`;
}
if (daysUntil(dateStr) < 0) {
dateStr = `${thisYear + 1}-${dateStr.slice(5)}`;
}
const rel = RELATIONS.find(r => r.id === p.relation);
items.push({ person: p, type: "birthday", label: "Birthday", emoji: "🎂", date: dateStr, rel });
}
if (p.occasion && p.eventDate) {
const occ = OCCASIONS.find(o => o.id === p.occasion);
items.push({ person: p, type: "occasion", label: occ?.label || p.occasion, emoji: occ?.emoji || "🎉", date: p.eventDate });
}
return items;
})
.sort((a, b) => daysUntil(a.date) - daysUntil(b.date));

const urgent = events.filter(e => { const d = daysUntil(e.date); return d !== null && d >= 0 && d <= 14; });
const soon = events.filter(e => { const d = daysUntil(e.date); return d !== null && d > 14 && d <= 60; });
const later = events.filter(e => { const d = daysUntil(e.date); return d !== null && d > 60; });

const EventRow = ({ ev, i }) => {
const d = new Date(ev.date + "T12:00:00");
const days = daysUntil(ev.date);
return (
<div onClick={() => { onLoadPerson(ev.person); onClose(); }} style={{
background: C.card, border: `1.5px solid ${C.border}`, borderRadius: 14,
padding: "13px 16px", cursor: "pointer",
display: "flex", alignItems: "center", gap: 12,
animation: `up .25s ease ${i * .05}s both`,
}}>
{ev.person.photo
? <img src={ev.person.photo} style={{ width: 40, height: 40, borderRadius: 10, objectFit: "cover" }} alt="" />
: <div style={{ width: 40, height: 40, borderRadius: 10, background: "#f5f0eb", display: "flex", alignItems: "center", justifyContent: "center", fontSize: 20 }}>{ev.emoji}</div>
}
<div style={{ flex: 1 }}>
<div style={{ fontWeight: 800, fontSize: 14, color: C.text }}>
{ev.person.name || ev.rel?.label} — {ev.label}
</div>
<div style={{ fontSize: 12, color: C.muted, marginTop: 2 }}>
{MONTHS[d.getMonth()]} {d.getDate()}, {d.getFullYear()}
</div>
</div>
<div style={{
fontSize: 12, fontWeight: 800,
color: days <= 7 ? "#e53935" : days <= 14 ? C.accent : C.muted,
textAlign: "right",
}}>
{days === 0 ? "Today!" : days === 1 ? "Tomorrow!" : `${days}d`}
</div>
</div>
);
};

const Group = ({ title, color, items }) => items.length === 0 ? null : (
<div style={{ marginBottom: 20 }}>
<div style={{ fontSize: 10, fontWeight: 800, letterSpacing: 1.5, color, textTransform: "uppercase", marginBottom: 10 }}>{title}</div>
<div style={{ display: "flex", flexDirection: "column", gap: 8 }}>
{items.map((ev, i) => <EventRow key={i} ev={ev} i={i} />)}
</div>
</div>
);

return (
<Sheet onClose={onClose} title="📅 Calendar">
{events.length === 0 ? (
<div style={{ textAlign: "center", padding: "36px 20px", color: C.muted, fontSize: 14 }}>
<div style={{ fontSize: 40, marginBottom: 10 }}>📅</div>
No events yet.<br />
Add birthdays and occasions when saving people.
</div>
) : (
<>
<Group title="🔴 Coming up (next 2 weeks)" color="#e53935" items={urgent} />
<Group title="🟡 Soon (next 2 months)" color={C.accent} items={soon} />
<Group title="Later" color={C.muted} items={later} />
</>
)}
</Sheet>
);
}

// ─── STORES SHEET ─────────────────────────────────────────────────────────────
function StoresSheet({ storeIds, onChange, custom, onCustomChange, onClose }) {
const [cName, setCN] = useState("");
const [cUrl, setCU] = useState("");
const [adding, setA] = useState(false);
const toggle = id => onChange(storeIds.includes(id) ? storeIds.filter(s => s !== id) : [...storeIds, id]);
const add = () => {
if (!cName || !cUrl) return;
onCustomChange([...custom, { id: "c_" + uid(), label: cName, url: cUrl.startsWith("http") ? cUrl : "https://" + cUrl }]);
setCN(""); setCU(""); setA(false);
};
return (
<Sheet onClose={onClose} title="🏪 Stores">
<div style={{ fontSize: 13, color: C.sub, marginBottom: 16 }}>
{storeIds.length + custom.length} selected — links open directly to your chosen stores
</div>
{STORE_CATALOG.map(cat => (
<div key={cat.cat} style={{ marginBottom: 16 }}>
<FL>{cat.cat}</FL>
<div style={{ display: "flex", flexWrap: "wrap", gap: 7 }}>
{cat.stores.map(s => (
<Chip key={s.id} label={s.label} active={storeIds.includes(s.id)} onClick={() => toggle(s.id)} />
))}
</div>
</div>
))}
{custom.length > 0 && (
<div style={{ marginBottom: 16 }}>
<FL>Your Stores</FL>
<div style={{ display: "flex", flexWrap: "wrap", gap: 7 }}>
{custom.map(s => (
<div key={s.id} style={{
display: "flex", alignItems: "center", gap: 5,
padding: "6px 10px 6px 13px", borderRadius: 999, background: C.accent, color: "#fff", fontSize: 13, fontWeight: 700,
}}>
{s.label}
<button onClick={() => onCustomChange(custom.filter(c => c.id !== s.id))} style={{
background: "none", border: "none", color: "#fff9", cursor: "pointer", fontFamily: "inherit", fontSize: 16, lineHeight: 1, padding: 0,
}}>×</button>
</div>
))}
</div>
</div>
)}
{!adding ? (
<button onClick={() => setA(true)} style={{
width: "100%", padding: 13, borderRadius: 12,
border: `2px dashed ${C.border}`, background: "transparent",
color: C.muted, fontSize: 13, fontWeight: 700, cursor: "pointer", fontFamily: "inherit",
}}>+ Add your own store</button>
) : (
<div style={{ display: "flex", flexDirection: "column", gap: 10, background: "#f5f0eb", borderRadius: 14, padding: 14 }}>
<TInput placeholder="Store name" value={cName} onChange={e => setCN(e.target.value)} />
<TInput placeholder="Search URL: https://store.com/search?q=" value={cUrl} onChange={e => setCU(e.target.value)} />
<div style={{ display: "flex", gap: 8 }}>
<button onClick={add} style={{ flex: 1, padding: 11, borderRadius: 10, border: "none", background: C.accent, color: "#fff", fontWeight: 800, cursor: "pointer", fontFamily: "inherit" }}>Add</button>
<button onClick={() => setA(false)} style={{ flex: 1, padding: 11, borderRadius: 10, border: `1px solid ${C.border}`, background: C.card, color: C.sub, fontWeight: 700, cursor: "pointer", fontFamily: "inherit" }}>Cancel</button>
</div>
</div>
)}
</Sheet>
);
}

// ─── BULK RESULTS SHEET ───────────────────────────────────────────────────────
function BulkResultsSheet({ data, storeIds, customStores, onClose }) {
const { group, occasion, occasionLabel, gifts } = data;
const [openIdx, setOpenIdx] = useState(null);
const byPerson = group.people.map((person, pi) => ({
person,
gifts: gifts.filter(g => g.personIndex === pi),
}));
return (
<Sheet onClose={onClose}>
<div style={{ display: "flex", alignItems: "center", gap: 12, marginBottom: 20 }}>
<div style={{ fontSize: 32 }}>{group.emoji}</div>
<div>
<div style={{ fontSize: 18, fontWeight: 900, color: C.text }}>{group.name}</div>
{/* FIX: show occasionLabel (handles both preset and custom occasions) */}
{occasionLabel && (
<div style={{ fontSize: 13, color: C.accent, fontWeight: 700 }}>
{occasion?.emoji || "🎉"} {occasionLabel} · {gifts.length} gift ideas
</div>
)}
</div>
</div>
<div style={{ display: "flex", flexDirection: "column", gap: 16 }}>
{byPerson.map(({ person, gifts: pg }, pi) => {
const rel = RELATIONS.find(r => r.id === person.relation);
return (
<div key={pi}>
<div style={{ display: "flex", alignItems: "center", gap: 10, marginBottom: 8 }}>
{person.photo
? <img src={person.photo} style={{ width: 36, height: 36, borderRadius: 10, objectFit: "cover" }} alt="" />
: <div style={{ width: 36, height: 36, borderRadius: 10, background: C.accentL, display: "flex", alignItems: "center", justifyContent: "center", fontSize: 18 }}>{rel?.emoji}</div>
}
<div style={{ fontWeight: 800, fontSize: 15, color: C.text }}>
{person.name || rel?.label}
</div>
{person.age && (
<span style={{ fontSize: 11, background: "#f5f0eb", color: C.sub, borderRadius: 6, padding: "2px 8px", fontWeight: 700 }}>{person.age}</span>
)}
</div>
<div style={{ display: "flex", flexDirection: "column", gap: 8, paddingLeft: 8 }}>
{pg.map((gift, gi) => {
const key = `${pi}-${gi}`;
const open = openIdx === key;
const links = mkLinks(gift.searchQuery || gift.title, storeIds, customStores);
return (
<div key={gi} style={{
background: C.card, border: `1.5px solid ${C.border}`,
borderRadius: 14, overflow: "hidden",
borderLeft: `3px solid ${C.accent}`,
}}>
<div onClick={() => setOpenIdx(open ? null : key)} style={{
padding: "12px 14px", cursor: "pointer",
display: "flex", justifyContent: "space-between", alignItems: "flex-start",
}}>
<div style={{ flex: 1 }}>
<div style={{ fontSize: 14, fontWeight: 800, color: C.text, lineHeight: 1.3 }}>{gift.title}</div>
<div style={{ fontSize: 11, color: C.accent, fontWeight: 700, marginTop: 3 }}>↗ {gift.trendReason}</div>
</div>
<span style={{ color: C.muted, fontSize: 11, flexShrink: 0, marginLeft: 8 }}>{open ? "▲" : "▼"}</span>
</div>
{open && (
<div style={{ padding: "0 14px 12px", borderTop: `1px solid ${C.border}` }}>
<p style={{ fontSize: 12, color: C.sub, lineHeight: 1.6, marginBottom: 10, marginTop: 10 }}>{gift.description}</p>
<div style={{ display: "flex", flexWrap: "wrap", gap: 6 }}>
{links.map((lk, li) => (
<a key={li} href={lk.url} target="_blank" rel="noreferrer" style={{
padding: "6px 12px", background: C.accent, color: "#fff",
borderRadius: 8, fontSize: 11, fontWeight: 800, textDecoration: "none",
}}>🛍 {lk.label}</a>
))}
</div>
</div>
)}
</div>
);
})}
</div>
</div>
);
})}
</div>
</Sheet>
);
}

// ─── MAIN APP ─────────────────────────────────────────────────────────────────
export default function App() {
const [relation, setRelation] = useState("");
const [forMe, setForMe] = useState(false);
const [name, setName] = useState("");
const [photo, setPhoto] = useState(null);
const [age, setAge] = useState("");
const [birthday, setBirthday] = useState("");
const [bdMonth, setBdMonth] = useState("");
const [bdDay, setBdDay] = useState("");
const [bdYear, setBdYear] = useState("");
const [occasion, setOccasion] = useState("");
const [customOccasion, setCustomOccasion] = useState("");
const [eventDate, setEventDate] = useState("");
const [evMonth, setEvMonth] = useState("");
const [evDay, setEvDay] = useState("");
const [evYear, setEvYear] = useState("");
const [budget, setBudget] = useState("");
const [interests, setInterests] = useState("");

// ── localStorage helpers ──
const load = (key, def) => { try { const v = localStorage.getItem(key); return v ? JSON.parse(v) : def; } catch { return def; } };
const save = (key, val) => { try { localStorage.setItem(key, JSON.stringify(val)); } catch {} };

const [results, setResults] = useState([]);
const [loading, setLoading] = useState(false);
const [error, setError] = useState(null);
const [storeIds, setStoreIds] = useState(() => load("pw_stores", DEFAULT_STORES));
// FIX: customStores now persisted in localStorage
const [customStores, setCustomStores] = useState(() => load("pw_custom_stores", []));
const [groups, setGroups] = useState(() => load("pw_groups", []));
const [people, setPeople] = useState(() => load("pw_people", []));
const [wishList, setWishList] = useState(() => load("pw_wishlist", []));
const [resultsCount, setResultsCount] = useState(4);
const [sortMode, setSortMode] = useState("trending");
  const [showMyPeople, setShowMyPeople] = useState(false);
  const [confirmDeletePerson, setConfirmDeletePerson] = useState(null);
const [myName, setMyName] = useState(() => load("pw_myname", ""));
const [myBdMonth, setMyBdMonth] = useState(() => load("pw_mybdm", ""));
// FIX: myBdDay now loads from localStorage
const [myBdDay, setMyBdDay] = useState(() => load("pw_mybdd", ""));
const [myBdYear, setMyBdYear] = useState(() => load("pw_mybdy", ""));
const [saved, setSaved] = useState(false);
const [sheet, setSheet] = useState(null);
const [savedMatches, setSavedMatches] = useState([]);
const [bulkResults, setBulkResults] = useState(null);
const [bulkLoading, setBulkLoading] = useState(false);

// ── Persisted setters ──
const setGroupsP = v => { const val = typeof v === "function" ? v(groups) : v; setGroups(val); save("pw_groups", val); };
const setPeopleP = v => { const val = typeof v === "function" ? v(people) : v; setPeople(val); save("pw_people", val); };
const setWishP = v => { const val = typeof v === "function" ? v(wishList) : v; setWishList(val); save("pw_wishlist", val); };
const setStoreP = v => { const val = typeof v === "function" ? v(storeIds) : v; setStoreIds(val); save("pw_stores", val); };
// FIX: customStores setter now persists
const setCustomStoresP = v => { const val = typeof v === "function" ? v(customStores) : v; setCustomStores(val); save("pw_custom_stores", val); };
// FIX: myName setter no longer calls itself recursively
const setMyNameP = v => { setMyName(v); save("pw_myname", v); };
const setMyBdMP = v => { setMyBdMonth(v); save("pw_mybdm", v); };
const setMyBdDP = v => { setMyBdDay(v); save("pw_mybdd", v); };
const setMyBdYP = v => { setMyBdYear(v); save("pw_mybdy", v); };

const rel = RELATIONS.find(r => r.id === relation);
const occ = OCCASIONS.find(o => o.id === occasion);
const bud = BUDGETS.find(b => b.id === budget);

const reset = () => {
setRelation(""); setForMe(false); setName(""); setPhoto(null);
setAge(""); setBirthday(""); setBdMonth(""); setBdDay(""); setBdYear("");
setOccasion(""); setEventDate(""); setEvMonth(""); setEvDay(""); setEvYear("");
setBudget(""); setInterests(""); setResults([]); setSaved(false);
};

const loadPerson = p => {
setRelation(p.relation || "");
setForMe(p.relation === "myself");
setName(p.name || "");
setPhoto(p.photo || null);
setAge(p.age || "");
setBirthday(p.birthday || "");
setBdMonth(""); setBdDay(""); setBdYear("");
setOccasion(p.occasion || "");
setEventDate(p.eventDate || "");
setBudget(p.budget || "");
setInterests(p.interests || "");
setResults([]); setSaved(false);
window.scrollTo({ top: 0, behavior: "smooth" });
};

const findSaved = (relId) => {
const all = [...people, ...groups.flatMap(g => g.people)]
.filter((p, i, arr) => arr.findIndex(x => x.id === p.id) === i);
return all.filter(p => p.relation === relId);
};

const currentPerson = () => ({
id: uid(), relation, name, photo, age,
birthday: [bdMonth, bdDay, bdYear].filter(Boolean).join(" "),
occasion, eventDate, budget, interests,
});

const addToWishList = (gift, links) => {
setWishP(prev =>
prev.find(x => x.title === gift.title)
? prev.filter(x => x.title !== gift.title)
: [...prev, { ...gift, id: uid(), storeLinks: links }]
);
};

const saveToGroup = (mode, groupData, person) => {
if (mode === "existing") {
setGroupsP(gs => gs.map(g =>
g.id === groupData
? { ...g, people: [...g.people.filter(p => p.id !== person.id), person] }
: g
));
} else {
setGroupsP(gs => [...gs, { id: uid(), ...groupData, people: [person] }]);
}
setPeopleP(prev => prev.find(p => p.id === person.id) ? prev : [...prev, person]);
setSaved(true);
};

const buildPrompt = () => {
const storeNames = [
...ALL_STORES.filter(s => storeIds.includes(s.id)).map(s => s.label),
...customStores.map(s => s.label),
].join(", ") || "Amazon";
const who = forMe ? "the user themselves (for their own wish list)" : `${rel?.label || "someone"}, interested in: ${interests || "general"}`;
return `You are a US gift trend expert for 2026. Preferred stores: ${storeNames}. Return ONLY valid JSON. Find gifts for: ${who}, age ${age || "unknown"}, budget ${bud?.label || "flexible"}${occ ? `, occasion: ${occ.label}` : ""}. Return ${resultsCount} trending gift ideas. Each: { "title": "Gift name", "searchQuery": "3-5 word search phrase", "trendReason": "Why trending in 2026 (max 8 words)", "description": "Why they will love it (2 sentences)", "category": "one of: Fashion, Tech, Home, Beauty, Food, Sports, Gaming, Books, Experience, Other", "priceHint": "one of: Budget, Mid-range, Premium, Luxury", "matchScore": 85 } Format: { "gifts": [ ... ] }`;
};

const findGifts = async () => {
if (!relation && !forMe) { setError("Select who this gift is for."); return; }
setError(null); setLoading(true); setResults([]); setSaved(false);
try {
const res = await fetch("https://api.anthropic.com/v1/messages", {
method: "POST",
headers: {
"Content-Type": "application/json",
// ⬇️ ДОБАВЬ СВОЙ API КЛЮЧ ЗДЕСЬ:
"x-api-key": "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",
"anthropic-version": "2023-06-01",
"anthropic-dangerous-direct-browser-access": "true",
},
body: JSON.stringify({
model: "claude-sonnet-4-5",
max_tokens: 2000,
messages: [{ role: "user", content: buildPrompt() }],
}),
});
const data = await res.json();
if (data.error) throw new Error(data.error.message);
const text = data.content.map(c => c.text || "").join("");
const parsed = JSON.parse(text.replace(/`json|`/g, "").trim());
setResults((parsed.gifts || []).map(g => ({ ...g, budget })));
setSortMode("trending");
} catch (e) {
setError("Something went wrong. Check your API key and try again.");
console.error(e);
} finally {
setLoading(false);
}
};

const hasSelection = relation || forMe;
const isForMe = forMe && !relation;

const upcomingCount = [...people, ...groups.flatMap(g => g.people)]
.filter((p, i, arr) => arr.findIndex(x => x.id === p.id) === i)
.filter(p => {
const d = daysUntil(p.birthday);
return d !== null && d >= 0 && d <= 30;
}).length;

const findGiftsForGroup = async (group, occasionId, customLabel, groupBudgetId) => {
if (!group.people.length) return;
setBulkLoading(true);
setBulkResults(null);
const storeNames = [
...ALL_STORES.filter(s => storeIds.includes(s.id)).map(s => s.label),
...customStores.map(s => s.label),
].join(", ") || "Amazon";
const occObj = OCCASIONS.find(o => o.id === occasionId);
// FIX: occasionLabel properly handles both preset and custom occasions
const occasionLabel = customLabel || occObj?.label || "Gift";
const list = group.people.map((p, i) => {
const rel = RELATIONS.find(r => r.id === p.relation);
const groupBudObj = BUDGETS.find(b => b.id === groupBudgetId);
      const bud = groupBudObj || BUDGETS.find(b => b.id === p.budget);
return `${i}. ${rel?.label || "Person"}${p.name ? " (" + p.name + ")" : ""}, age ${p.age || "unknown"}, budget ${bud?.label || "flexible"}${p.interests ? ", likes: " + p.interests : ""}`;
}).join("\n");
const prompt = `You are a US gift trend expert for 2026. Preferred stores: ${storeNames}. Return ONLY valid JSON. Find 2 trending gift ideas for each person: ${list} Each idea: { "personIndex": 0, "title": "Gift name", "searchQuery": "3-5 word search phrase", "trendReason": "Why trending in 2026 (max 8 words)", "description": "Why they will love it (2 sentences)", "category": "Fashion, Tech, Home, Beauty, Food, Sports, Gaming, Books, Experience, or Other", "priceHint": "Budget, Mid-range, Premium, or Luxury" } Format: { "gifts": [ ... ] }`;
try {
const res = await fetch("https://api.anthropic.com/v1/messages", {
method: "POST",
headers: {
"Content-Type": "application/json",
// ⬇️ ДОБАВЬ СВОЙ API КЛЮЧ ЗДЕСЬ:
"x-api-key": "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",
"anthropic-version": "2023-06-01",
"anthropic-dangerous-direct-browser-access": "true",
},
body: JSON.stringify({ model: "claude-sonnet-4-5", max_tokens: 2000, messages: [{ role: "user", content: prompt }] }),
});
const data = await res.json();
if (data.error) throw new Error(data.error.message);
const text = data.content.map(c => c.text || "").join("");
const parsed = JSON.parse(text.replace(/`json|`/g, "").trim());
const mapped = (parsed.gifts || []).map(g => ({
...g,
person: group.people[g.personIndex],
budget: group.people[g.personIndex]?.budget || "",
}));
// FIX: pass occasionLabel to BulkResultsSheet
setBulkResults({ group, occasion: occObj, occasionLabel, gifts: mapped });
setSheet(null);
} catch(e) {
console.error(e);
} finally {
setBulkLoading(false);
}
};

return (
<>
<style>{css}</style>
<div className="pw-app" style={{ minHeight: "100vh", background: C.bg, maxWidth: 680, margin: "0 auto", padding: "0 0 40px" }}>
{/* ── HEADER ── */}
<div style={{ padding: "52px 20px 20px" }}>
<div style={{ marginBottom: 4, display: "flex", alignItems: "center", gap: 14 }}>
<img src={LOGO_IMG} alt="Pickwell" style={{ height: 52, width: 52, objectFit: "contain", borderRadius: 12 }} />
<div>
<div style={{ fontSize: 26, fontWeight: 900, color: C.text, lineHeight: 1.15 }}>Pickwell</div>
<div style={{ fontSize: 12, color: C.accent, fontWeight: 700, letterSpacing: 1, textTransform: "uppercase" }}>Find the perfect gift</div>
</div>
</div>


      {/* ── 4-BUTTON NAV ── */}
      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr 1fr", gap: 8, marginTop: 20 }}>
        {[
          { id: "wishlist", Icon: Icon.WishList, label: wishList.length > 0 ? `${wishList.length} saved` : "Wish List", active: wishList.length > 0, activeBg: "#fdf0eb", labelColor: ICON_COLOR.wish },
          { id: "groups", Icon: Icon.Groups, label: groups.length > 0 ? `${groups.length} groups` : "Groups", active: false, activeBg: "#f5ede8", labelColor: ICON_COLOR.groups },
          { id: "calendar", Icon: Icon.Calendar, label: upcomingCount > 0 ? `${upcomingCount} soon` : "Calendar", active: upcomingCount > 0, activeBg: "#fdf0eb", labelColor: ICON_COLOR.calendar },
          { id: "stores", Icon: Icon.Stores, label: `${storeIds.length + customStores.length} stores`, active: false, activeBg: "#f5ede8", labelColor: ICON_COLOR.stores },
        ].map(btn => (
          <button key={btn.id} onClick={() => setSheet(btn.id)} style={{
            padding: "12px 6px", borderRadius: 14, cursor: "pointer",
            border: `1.5px solid ${btn.active ? btn.labelColor + "44" : C.border}`,
            background: btn.active ? btn.activeBg : C.card,
            display: "flex", flexDirection: "column", alignItems: "center", gap: 5,
            transition: "all .18s",
          }}>
            <btn.Icon />
            <span style={{ fontSize: 10, fontWeight: 800, color: btn.labelColor, textAlign: "center", lineHeight: 1.2 }}>{btn.label}</span>
          </button>
        ))}
      </div>
    </div>

    {/* ── SEARCH FORM ── */}
    <div style={{ padding: "0 20px" }}>
      <div style={{
        background: C.card, border: `1.5px solid ${C.border}`,
        borderRadius: 20, padding: "18px 18px 20px",
        animation: "up .3s ease",
      }}>
        {/* WHO */}
            {showMyPeople && (
              <div style={{ position: "fixed", top: 0, left: 0, right: 0, bottom: 0, background: "rgba(0,0,0,0.4)", zIndex: 999, display: "flex", alignItems: "center", justifyContent: "center" }}>
                <div style={{ background: C.card, borderRadius: 20, padding: 24, width: 340, maxHeight: "80vh", overflowY: "auto" }}>
                  <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 16 }}>
                    <div style={{ fontWeight: 800, fontSize: 16 }}>👥 My People</div>
                    <button onClick={() => setShowMyPeople(false)} style={{ background: "none", border: "none", fontSize: 20, cursor: "pointer" }}>✕</button>
                  </div>
                  {people.length === 0 && <div style={{ color: C.sub, fontSize: 13 }}>No saved people yet</div>}
                  {people.map(p => (
                    <div key={p.id} style={{ display: "flex", alignItems: "center", justifyContent: "space-between", padding: "10px 0", borderBottom: `1px solid ${C.border}` }}>
                      <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
                        {p.photo ? <img src={p.photo} style={{ width: 36, height: 36, borderRadius: 10, objectFit: "cover" }} alt="" /> : <div style={{ width: 36, height: 36, borderRadius: 10, background: "#f5f0eb", display: "flex", alignItems: "center", justifyContent: "center", fontSize: 18 }}>👤</div>}
                        <div>
                          <div style={{ fontWeight: 700, fontSize: 14 }}>{p.name || "Unnamed"}</div>
                          <div style={{ fontSize: 12, color: C.sub }}>{p.age}{p.relation ? ` · ${p.relation}` : ""}</div>
                        </div>
                      </div>
                      <button onClick={() => {
                        if (window.confirm(`Delete ${p.name || "this person"}?`)) {
                          const newPeople = people.filter(x => x.id !== p.id);
                          setPeople(newPeople);
                          const newGroups = groups.map(g => ({ ...g, people: g.people.filter(x => x.id !== p.id) }));
                          setGroups(newGroups);
                        }
                      }} style={{ background: "none", border: "none", fontSize: 18, cursor: "pointer", color: "#e74c3c" }}>🗑️</button>
                    </div>
                  ))}
                </div>
              </div>
            )}
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center" }}><FL>Who is the gift for?</FL><button onClick={() => setShowMyPeople(true)} style={{ fontSize: 12, color: C.accent, background: "none", border: "none", cursor: "pointer", fontWeight: 700 }}>👥 My People</button></div>
        <div style={{ display: "flex", gap: 7, overflowX: "auto", paddingBottom: 6, marginBottom: 4 }}>
          {RELATIONS.map(r => {
            const isForMeBtn = r.id === "myself";
            const isActive = isForMeBtn ? forMe : relation === r.id;
            return (
              <button key={r.id} onClick={() => {
                if (isForMeBtn) { setForMe(f => !f); setRelation(""); setSavedMatches([]); }
                else {
                  const newRel = relation === r.id ? "" : r.id;
                  setRelation(newRel); setForMe(false); setResults([]);
                  if (newRel) { setSavedMatches(findSaved(newRel)); } else { setSavedMatches([]); }
                }
              }} style={{
                padding: "7px 14px", borderRadius: 999, flexShrink: 0, cursor: "pointer",
                border: `1.5px solid ${isActive ? (isForMeBtn ? C.gold : C.accent) : C.border}`,
                background: isActive ? (isForMeBtn ? C.goldL : C.accentL) : "transparent",
                color: isActive ? (isForMeBtn ? C.gold : C.accent) : C.sub,
                fontSize: 13, fontWeight: 700, fontFamily: "inherit",
                whiteSpace: "nowrap", transition: "all .13s",
              }}>{r.emoji} {r.label}</button>
            );
          })}
        </div>

        {/* Quick load */}
        {savedMatches.length > 0 && (
          <div style={{ marginTop: 10, marginBottom: 4 }}>
            <div style={{ fontSize: 10, fontWeight: 800, color: C.accent, letterSpacing: 1.2, textTransform: "uppercase", marginBottom: 6 }}>Saved — tap to load</div>
            <div style={{ display: "flex", gap: 7, overflowX: "auto", paddingBottom: 4 }}>
              {savedMatches.map(p => (
                <button key={p.id} onClick={() => { loadPerson(p); setSavedMatches([]); }} style={{
                  display: "flex", alignItems: "center", gap: 8, flexShrink: 0,
                  padding: "8px 14px", borderRadius: 12,
                  border: `1.5px solid ${C.accent}`, background: C.accentL,
                  cursor: "pointer", fontFamily: "inherit",
                }}>
                  {p.photo
                    ? <img src={p.photo} style={{ width: 28, height: 28, borderRadius: 7, objectFit: "cover" }} alt="" />
                    : <span style={{ fontSize: 18 }}>{RELATIONS.find(r => r.id === p.relation)?.emoji}</span>
                  }
                  <div style={{ textAlign: "left" }}>
                    <div style={{ fontSize: 13, fontWeight: 800, color: C.accent }}>{p.name || RELATIONS.find(r => r.id === p.relation)?.label}</div>
                    {p.age && <div style={{ fontSize: 11, color: C.sub }}>{p.age}</div>}
                  </div>
                </button>
              ))}
              <button onClick={() => setSavedMatches([])} style={{
                flexShrink: 0, padding: "8px 12px", borderRadius: 12,
                border: `1.5px solid ${C.border}`, background: "transparent",
                cursor: "pointer", fontSize: 12, color: C.muted, fontFamily: "inherit", fontWeight: 700,
              }}>Fill new</button>
            </div>
          </div>
        )}

        {hasSelection && (
          <>
            <Sep />
            {!forMe && (
              <div style={{ display: "flex", gap: 12, alignItems: "center", marginTop: 16, marginBottom: 16 }}>
                <PhotoPicker photo={photo} onPhoto={setPhoto} />
                <div style={{ flex: 1 }}>
                  <FL>Name (optional)</FL>

                    {relation === "pet" && (
                      <div style={{ marginTop: 12, marginBottom: 16 }}>
                        <FL>Pet Type</FL>
                        <div style={{ display: "flex", flexWrap: "wrap", gap: 7, marginBottom: 10 }}>
                          {["🐶 Dog","🐱 Cat","🐦 Bird","🐹 Small Pet","🐟 Fish","🐾 Other"].map(t => (
                            <Chip key={t} label={t} active={interests.includes(t)} onClick={() =>
                              setInterests(p =>
                                p.includes(t)
                                  ? p.replace(", "+t,"").replace(t+", ","").replace(t,"")
                                  : p ? p+", "+t : t
                              )
                            } />
                          ))}
                        </div>

                        <FL>Pet Personality</FL>
                        <div style={{ display: "flex", flexWrap: "wrap", gap: 7 }}>
                          {["Playful","Calm","Active","Senior","Luxury","Funny"].map(t => (
                            <Chip key={t} label={t} active={interests.includes(t)} onClick={() =>
                              setInterests(p =>
                                p.includes(t)
                                  ? p.replace(", "+t,"").replace(t+", ","").replace(t,"")
                                  : p ? p+", "+t : t
                              )
                            } />
                          ))}
                        </div>
                      </div>
                    )}
                  <TInput
                    placeholder={relation === "custom" ? "e.g. Employee, Neighbor..." : `e.g. ${rel?.label || ""}...`}
                    value={name}
                    onChange={e => setName(e.target.value)}
                  />
                </div>
              </div>
            )}
            {forMe && (
              <div style={{ marginTop: 16, marginBottom: 16 }}>
                <FL>Your Name</FL>
                <TInput placeholder="e.g. Anna, Jake..." value={myName} onChange={e => setMyNameP(e.target.value)} />
                <div style={{ marginTop: 12 }}>
                  <FL>Your Birthday (optional)</FL>
                  <div style={{ display: "flex", gap: 8 }}>
                    {[
                      { key: "m", placeholder: "Month", opts: MONTHS },
                      { key: "d", placeholder: "Day", opts: Array.from({length:31},(_,i) => String(i+1)) },
                      { key: "y", placeholder: "Year", opts: Array.from({length:80},(_,i) => String(new Date().getFullYear() - i)) },
                    ].map(f => (
                      <select key={f.key}
                        value={f.key==="m" ? myBdMonth : f.key==="d" ? myBdDay : myBdYear}
                        onChange={e => {
                          if (f.key==="m") setMyBdMP(e.target.value);
                          if (f.key==="d") setMyBdDP(e.target.value);
                          if (f.key==="y") setMyBdYP(e.target.value);
                        }}
                        style={{
                          flex: f.key==="y" ? 1.4 : 1, padding: "11px 8px", fontSize: 14,
                          border: `1.5px solid ${C.border}`, borderRadius: 12,
                          background: C.card, color: C.text, fontFamily: "inherit", outline: "none",
                          appearance: "none", WebkitAppearance: "none", textAlign: "center",
                        }}>
                        <option value="">{f.placeholder}</option>
                        {f.opts.map(o => <option key={o} value={o}>{o}</option>)}
                      </select>
                    ))}
                  </div>
                </div>
              </div>
            )}

            {!forMe && (
              <>
                <Sep />
                <div style={{ marginTop: 16, marginBottom: 16 }}>
                  <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 8 }}>
                    <FL>Birthday</FL>
                    {(bdMonth || bdDay || bdYear) && (
                      <button onClick={() => { setBdMonth(""); setBdDay(""); setBdYear(""); }} style={{
                        background: "none", border: "none", fontSize: 11,
                        color: C.muted, cursor: "pointer", fontFamily: "inherit", fontWeight: 700,
                      }}>Clear</button>
                    )}
                  </div>
                  <div style={{ display: "flex", gap: 8 }}>
                    {[
                      { key: "bMonth", placeholder: "Month", opts: MONTHS },
                      { key: "bDay", placeholder: "Day", opts: Array.from({length:31},(_,i) => String(i+1)) },
                      { key: "bYear", placeholder: "Year", opts: Array.from({length:80},(_,i) => String(new Date().getFullYear() - i)) },
                    ].map(f => (
                      <select key={f.key}
                        value={f.key === "bMonth" ? bdMonth : f.key === "bDay" ? bdDay : bdYear}
                        onChange={e => {
                          if (f.key === "bMonth") setBdMonth(e.target.value);
                          if (f.key === "bDay") setBdDay(e.target.value);
                          if (f.key === "bYear") setBdYear(e.target.value);
                          setAge("");
                        }}
                        style={{
                          flex: f.key === "bYear" ? 1.4 : 1, padding: "11px 8px", fontSize: 14,
                          border: `1.5px solid ${C.border}`, borderRadius: 12,
                          background: C.card, color: C.text, fontFamily: "inherit", outline: "none",
                          appearance: "none", WebkitAppearance: "none", textAlign: "center",
                        }}>
                        <option value="">{f.placeholder}</option>
                        {f.opts.map(o => <option key={o} value={o}>{o}</option>)}
                      </select>
                    ))}
                  </div>
                  {!bdMonth && !bdYear && !bdDay && (
                    <div style={{ marginTop: 12 }}>
                      <div style={{ fontSize: 11, color: C.muted, fontWeight: 700, marginBottom: 8 }}>OR SELECT AGE RANGE</div>
                      <div style={{ display: "flex", flexWrap: "wrap", gap: 7 }}>
                        {AGES.map(a => (
                          <Chip key={a} label={a} active={age === a} onClick={() => setAge(x => x === a ? "" : a)} />
                        ))}
                      </div>
                    </div>
                  )}
                </div>
              </>
            )}

            {forMe && (
              <>
                <Sep />
                <div style={{ marginTop: 16, marginBottom: 16 }}>
                  <FL>Age Range</FL>
                  <div style={{ display: "flex", flexWrap: "wrap", gap: 7 }}>
                    {AGES.map(a => (
                      <Chip key={a} label={a} active={age === a} onClick={() => setAge(x => x === a ? "" : a)} />
                    ))}
                  </div>
                </div>
              </>
            )}

            <Sep />
            <div style={{ marginTop: 16, marginBottom: occasion ? 12 : 16 }}>
              <FL>Occasion</FL>
              <div style={{ display: "flex", gap: 7, overflowX: "auto", paddingBottom: 4, marginBottom: 4 }}>
                {OCCASIONS.map(o => (
                  <Chip key={o.id} label={`${o.emoji} ${o.label}`} active={occasion === o.id}
                    onClick={() => { setOccasion(x => x === o.id ? "" : o.id); setEventDate(""); setEvMonth(""); setEvDay(""); setEvYear(""); }} />
                ))}
              </div>
            </div>

            {occasion && (
              <div style={{ marginBottom: 16 }}>
                <FL>Event Date</FL>
                <div style={{ display: "flex", gap: 8 }}>
                  {[
                    { key: "em", placeholder: "Month", opts: MONTHS },
                    { key: "ed", placeholder: "Day", opts: Array.from({length:31},(_,i) => String(i+1)) },
                    { key: "ey", placeholder: "Year", opts: ["2025","2026","2027","2028"] },
                  ].map(f => (
                    <select key={f.key}
                      value={f.key==="em" ? evMonth : f.key==="ed" ? evDay : evYear}
                      onChange={e => {
                        if (f.key==="em") setEvMonth(e.target.value);
                        if (f.key==="ed") setEvDay(e.target.value);
                        if (f.key==="ey") setEvYear(e.target.value);
                        setEventDate([
                          f.key==="em" ? e.target.value : evMonth,
                          f.key==="ed" ? e.target.value : evDay,
                          f.key==="ey" ? e.target.value : evYear,
                        ].filter(Boolean).join(" "));
                      }}
                      style={{
                        flex: f.key==="ey" ? 1.4 : 1, padding: "10px 8px", fontSize: 14,
                        border: `1.5px solid ${C.border}`, borderRadius: 12,
                        background: C.card, color: C.text, fontFamily: "inherit", outline: "none",
                        appearance: "none", WebkitAppearance: "none", textAlign: "center",
                      }}>
                      <option value="">{f.placeholder}</option>
                      {f.opts.map(o => <option key={o} value={o}>{o}</option>)}
                    </select>
                  ))}
                </div>
              </div>
            )}

            <Sep />
            <div style={{ marginTop: 16, marginBottom: 16 }}>
              <FL>Budget</FL>
              <div style={{ display: "flex", flexWrap: "wrap", gap: 7 }}>
                {BUDGETS.map(b => (
                  <Chip key={b.id} label={b.label} active={budget === b.id} onClick={() => setBudget(x => x === b.id ? "" : b.id)} />
                ))}
              </div>
            </div>

            <Sep />
            <div style={{ marginTop: 16, marginBottom: 16 }}>
              <FL>Interests & Hobbies</FL>
                  <div style={{ display: "flex", flexWrap: "wrap", gap: 6, marginBottom: 8 }}>
                    {[
                      "Cooking","Gardening","Reading","Fishing","Golf",
                      "Walking","Travel","Coffee","BBQ","Tools",
                      "Music","Movies","Fitness","Tech","DIY",
                      "Art","Pets","Camping","History","Comfort"
                    ].map(tag => (
                      <Chip
                        key={tag}
                        label={tag}
                        active={interests.split(", ").includes(tag)}
                        onClick={() =>
                          setInterests(prev => {
                            const arr = prev ? prev.split(", ").filter(Boolean) : [];
                            return arr.includes(tag)
                              ? arr.filter(x => x !== tag).join(", ")
                              : [...arr, tag].join(", ");
                          })
                        }
                      />
                    ))}
                  </div>
              <TInput
                placeholder="hiking, gaming, skincare, cooking..."
                value={interests}
                onChange={e => setInterests(e.target.value)}
              />
            </div>

            <Sep />
            <div style={{ display: "flex", gap: 8, marginTop: 14 }}>
              <button onClick={() => setSheet("saveGroup")} style={{
                flex: 1, padding: "9px 12px", borderRadius: 10,
                border: `1.5px solid ${C.border}`, background: "#f5f0eb",
                color: C.accent, fontSize: 13, fontWeight: 800,
                cursor: "pointer", fontFamily: "inherit",
              }}>
                <svg width="15" height="15" viewBox="0 0 15 15" fill="none" style={{display:"inline",verticalAlign:"middle",marginRight:5}}>
                  <circle cx="6" cy="4.5" r="2.2" stroke="currentColor" strokeWidth="1.5"/>
                  <path d="M1 13c0-2.76 2.24-5 5-5s5 2.24 5 5" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round"/>
                  <path d="M12 7v4M10 9h4" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round"/>
                </svg>Add to Group</button>
              <button onClick={() => setSheet("createGroup")} style={{
                flex: 1, padding: "9px 12px", borderRadius: 10,
                border: `1.5px solid ${C.border}`, background: "#f5f0eb",
                color: C.sub, fontSize: 13, fontWeight: 800,
                cursor: "pointer", fontFamily: "inherit",
              }}>＋ New Group</button>
            </div>
          </>
        )}
      </div>

      {hasSelection && (
        <div style={{ marginBottom: 14, marginTop: 16, display: "flex", alignItems: "center", gap: 10 }}>
          <div style={{ fontSize: 12, fontWeight: 800, color: C.muted, whiteSpace: "nowrap" }}>IDEAS TO SHOW</div>
          <div style={{ display: "flex", gap: 6 }}>
            {[2, 4, 6, 10].map(n => (
              <button key={n} onClick={() => setResultsCount(n)} style={{
                width: 36, height: 36, borderRadius: 10, cursor: "pointer",
                border: `1.5px solid ${resultsCount === n ? C.accent : C.border}`,
                background: resultsCount === n ? C.accentL : C.card,
                color: resultsCount === n ? C.accent : C.sub,
                fontSize: 13, fontWeight: 800, fontFamily: "inherit", transition: "all .13s",
              }}>{n}</button>
            ))}
          </div>
        </div>
      )}

      {error && (
        <div style={{ color: "#e53935", fontSize: 13, fontWeight: 700, margin: "10px 0", padding: "10px 14px", background: "#fff5f5", borderRadius: 10, border: "1px solid #ffcdd2" }}>{error}</div>
      )}

      <button onClick={findGifts} disabled={loading || !hasSelection} style={{
        width: "100%", padding: 15, borderRadius: 14, border: "none",
        background: !hasSelection ? C.border : loading ? C.accentL : C.accent,
        color: !hasSelection ? C.muted : loading ? C.accent : "#fff",
        fontSize: 16, fontWeight: 900,
        cursor: !hasSelection || loading ? "not-allowed" : "pointer",
        display: "flex", alignItems: "center", justifyContent: "center", gap: 10,
        margin: "14px 0 24px", transition: "all .2s", fontFamily: "inherit",
        boxShadow: hasSelection && !loading ? "0 4px 20px rgba(194,113,79,.3)" : "none",
      }}>
        {loading ? (
          <>
            <span style={{
              width: 18, height: 18, borderRadius: "50%",
              border: `2px solid ${C.accentL}`, borderTopColor: C.accent,
              display: "inline-block", animation: "spin .7s linear infinite",
            }} />
            Finding gifts...
          </>
        ) : `🎁 Find Gift${forMe ? " for Me" : rel ? ` for ${name || rel.label}` : ""}`}
      </button>

      {results.length > 0 && (
        <div style={{ animation: "up .3s ease" }}>
          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 14 }}>
            <div style={{ fontSize: 15, fontWeight: 800, color: C.text }}>
              {results.length} ideas {forMe ? "for you" : `for ${name || rel?.label}`}
            </div>
            <button onClick={reset} style={{ background: "none", border: "none", fontSize: 12, color: C.muted, cursor: "pointer", fontFamily: "inherit", fontWeight: 700 }}>New search</button>
          </div>
          <div style={{ display: "flex", background: "#ede9e3", borderRadius: 12, padding: 3, marginBottom: 14 }}>
            {[
              { id: "trending", label: "🔥 Trending" },
              { id: "price", label: "💰 Price" },
              { id: "match", label: "⭐ Match" },
            ].map(tab => (
              <button key={tab.id} onClick={() => setSortMode(tab.id)} style={{
                flex: 1, padding: "8px 4px", borderRadius: 9, border: "none",
                cursor: "pointer", fontFamily: "inherit", fontSize: 12, fontWeight: 800,
                background: sortMode === tab.id ? C.card : "transparent",
                color: sortMode === tab.id ? C.accent : C.muted,
                boxShadow: sortMode === tab.id ? "0 1px 4px rgba(0,0,0,.08)" : "none",
                transition: "all .15s",
              }}>{tab.label}</button>
            ))}
          </div>
          <div style={{ display: "flex", flexDirection: "column", gap: 10, marginBottom: 20 }}>
            {[...results].sort((a,b) => {
              if (sortMode === "price") {
                const order = { Budget:1, "Mid-range":2, Premium:3, Luxury:4 };
                return (order[a.priceHint]||2) - (order[b.priceHint]||2);
              }
              if (sortMode === "match") return (b.matchScore||0) - (a.matchScore||0);
              return 0;
            }).map((g, i) => (
              <GiftCard key={i} gift={g} idx={i}
                storeIds={storeIds} customStores={customStores}
                onWish={forMe ? addToWishList : null}
                isWished={wishList.some(w => w.title === g.title)} />
            ))}
          </div>
          {!forMe && (
            !saved ? (
              <button onClick={() => setSheet("saveGroup")} style={{
                width: "100%", padding: 13, borderRadius: 13,
                border: `1.5px solid ${C.border}`, background: C.card, color: C.sub,
                fontSize: 14, fontWeight: 800, cursor: "pointer", fontFamily: "inherit",
                display: "flex", alignItems: "center", justifyContent: "center", gap: 8,
              }}>
                <svg width="15" height="15" viewBox="0 0 15 15" fill="none" style={{display:"inline",verticalAlign:"middle",marginRight:5}}>
                  <circle cx="6" cy="4.5" r="2.2" stroke="currentColor" strokeWidth="1.5"/>
                  <path d="M1 13c0-2.76 2.24-5 5-5s5 2.24 5 5" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round"/>
                  <path d="M12 7v4M10 9h4" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round"/>
                </svg>Save {name || rel?.label} to a Group</button>
            ) : (
              <div style={{
                padding: 13, borderRadius: 13, background: "#e8f5e9",
                border: "1.5px solid #a5d6a7", textAlign: "center",
                fontSize: 13, fontWeight: 700, color: "#388e3c",
              }}>✓ Saved to group!</div>
            )
          )}
        </div>
      )}
    </div>

    {/* ── SHEETS ── */}
    {bulkLoading && (
      <div style={{
        position: "fixed", bottom: 32, left: "50%", transform: "translateX(-50%)",
        background: C.text, color: "#fff", borderRadius: 14,
        padding: "12px 20px", fontSize: 13, fontWeight: 700,
        display: "flex", alignItems: "center", gap: 10, zIndex: 300,
        boxShadow: "0 8px 30px rgba(0,0,0,.2)", animation: "up .3s ease",
      }}>
        <span style={{ width: 16, height: 16, borderRadius: "50%", border: "2px solid #ffffff44", borderTopColor: "#fff", display: "inline-block", animation: "spin .7s linear infinite" }} />
        Finding gifts for everyone...
      </div>
    )}

    {bulkResults && (
      <BulkResultsSheet data={bulkResults} storeIds={storeIds} customStores={customStores} onClose={() => setBulkResults(null)} />
    )}
    {sheet === "wishlist" && (
      <WishListSheet wishList={wishList} onRemove={id => setWishP(w => w.filter(x => x.id !== id))}
        onClear={() => setWishP([])} onClose={() => setSheet(null)}
        myName={myName} myBirthday={[myBdMonth, myBdDay, myBdYear].filter(Boolean).join(" ")} />
    )}
    {sheet === "groups" && (
      <GroupsSheet groups={groups}
        onLoadPerson={p => { loadPerson(p); setSheet(null); }}
        onCreate={g => setGroupsP(gs => [...gs, g])}
        onClose={() => setSheet(null)}
        onBulkSearch={(g, occ, customLabel, gb) => findGiftsForGroup(g, occ, customLabel, gb)}
        bulkLoading={bulkLoading}
        onDelete={id => setGroupsP(gs => gs.filter(g => g.id !== id))} />
    )}
    {sheet === "calendar" && (
      <CalendarSheet people={people} groups={groups}
        onLoadPerson={p => { loadPerson(p); setSheet(null); }}
        onClose={() => setSheet(null)} />
    )}
    {sheet === "stores" && (
      <StoresSheet storeIds={storeIds} onChange={setStoreP}
        custom={customStores} onCustomChange={setCustomStoresP}
        onClose={() => setSheet(null)} />
    )}
    {sheet === "saveGroup" && (
      <SaveToGroupSheet person={currentPerson()} groups={groups}
        onSave={saveToGroup} onClose={() => setSheet(null)} />
    )}
    {sheet === "createGroup" && (
      <GroupsSheet groups={groups}
        onLoadPerson={p => { loadPerson(p); setSheet(null); }}
        onCreate={g => setGroupsP(gs => [...gs, g])}
        onClose={() => setSheet(null)}
        onBulkSearch={(g, occ, customLabel, gb) => findGiftsForGroup(g, occ, customLabel, gb)}
        bulkLoading={bulkLoading}
        onDelete={id => setGroupsP(gs => gs.filter(g => g.id !== id))} />
    )}
  </div>
</>
);
}